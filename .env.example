TELEGRAM_BOT_TOKEN=123456:replace_me
DATABASE_URL=postgres://user:password@host:5432/dbname?sslmode=require
PORT=8080

# Runtime mode
# webhook is recommended for Render/production because it avoids getUpdates conflicts.
# polling is still supported for local development.
BOT_MODE=webhook

# Webhook mode
# Use your public Render URL. If this URL has no path, TELEGRAM_WEBHOOK_PATH is appended automatically.
# Example: https://telemod-bot.onrender.com/tg-webhook
TELEGRAM_WEBHOOK_URL=https://your-render-service.onrender.com/tg-webhook
TELEGRAM_WEBHOOK_PATH=/tg-webhook
# Make this long and private. Telegram sends it in X-Telegram-Bot-Api-Secret-Token.
TELEGRAM_WEBHOOK_SECRET_TOKEN=change_me_to_a_long_random_secret_at_least_16_chars
BOT_SET_WEBHOOK_ON_START=true
BOT_WEBHOOK_MAX_BODY_BYTES=2097152
# Set true only if you want to discard old Telegram updates during deploy/restart.
BOT_DROP_PENDING_UPDATES_ON_START=false

# Polling mode only
# Delete old Telegram webhook before long polling. Used only when BOT_MODE=polling.
BOT_DELETE_WEBHOOK_ON_START=true
# Keep false. In polling mode, false uses a Postgres advisory lock so only one instance polls.
BOT_DISABLE_DB_POLLING_LOCK=false

# Bot-level owners (Telegram numeric user IDs). These users can open /admin in private.
# Keep this separate from group/channel owners. Example: BOT_OWNER_IDS=123456789,987654321
BOT_OWNER_IDS=

# Default false: bot owners cannot manage customer groups unless they are also the Telegram creator.
# Set true only for emergency support/maintenance.
BOT_OWNER_CAN_MANAGE_GROUPS=false

# Performance tuning
BOT_UPDATE_WORKERS=32
BOT_UPDATE_QUEUE_SIZE=2048
BOT_AUDIT_QUEUE_SIZE=1024
BOT_METRIC_QUEUE_SIZE=2048
BOT_ADMIN_CACHE_TTL=5m

# Moderation timing
BOT_CAPTCHA_TTL=60s
BOT_CAPTCHA_NOTICE_TTL=8s
BOT_STRIKE_WARN_TTL=5s
BOT_DAILY_REPORT_CRON=0 0 * * *

# Anti-flood: more than 5 messages in 3 seconds triggers a strike
BOT_FLOOD_LIMIT=5
BOT_FLOOD_WINDOW=3s

# DB-backed task queue
BOT_TASK_POLL_INTERVAL=5s
BOT_TASK_BATCH_SIZE=25
BOT_TASK_MAX_ATTEMPTS=5
BOT_TASK_CLEANUP_AGE=72h
BOT_TASK_CLEANUP_INTERVAL=1h

# Postgres pool
DB_MAX_CONNS=20
DB_MIN_CONNS=2

# Safety
# Default true: Telegram group/channel admins are exempt from auto-moderation checks.
BOT_EXEMPT_ADMINS=true
# Per-user cooldown for /report inside each group/channel.
BOT_REPORT_COOLDOWN=30s
